## 按年龄+移植分组的KM曲线
data_input$transplant_group <- ifelse(
data_input$X2 == 1,
"Transplant",
"No transplant"
)
data_input$group4 <- interaction(
data_input$age_group,
data_input$transplant_group,
sep = " & "
)
km_fit4 <- survfit(
Surv(Start, Stop, Event) ~ group4,
data = data_input
)
plot(
km_fit4,
col = c("#2E86C1","#3498DB","#E74C3C","#C0392B"),
lwd = 2,
lty = 1,
conf.int = FALSE,        # 置信区间
mark.time = TRUE,       # 删失标记
xlab = "Follow-up time",
ylab = "Survival probability",
main = "Kaplan–Meier Curves by Age Threshold and Transplant Status"
)
